# Copy to .env. NEVER commit the real .env.
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# Database — MySQL (a MySQL server is already running locally).
# Create it first:  CREATE DATABASE fishfarm CHARACTER SET utf8mb4;
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fishfarm
DB_USER=root
DB_PASSWORD=

# Set DB_DIALECT=sqlite to use a local file DB for quick dev (no MySQL needed).
SQLITE_STORAGE=./fishfarm.dev.sqlite

# CORS — the React dev server
CORS_ORIGIN=http://localhost:5174

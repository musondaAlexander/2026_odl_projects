{
  "name": "zero-knowledge-password-manager",
  "version": "0.1.0",
  "description": "Zero-knowledge desktop password manager (Electron + React, AES-256-GCM + PBKDF2)",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:start:electron\"",
    "start:electron": "cross-env ELECTRON_RENDERER_URL=http://localhost:5175 electron .",
    "start": "electron .",
    "test": "node --test"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1"
  }
}

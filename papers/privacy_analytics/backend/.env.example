# Copy to .env. NEVER commit the real .env.
JWT_SECRET=change-me-to-a-long-random-secret
# MySQL (live). Password @ must be URL-encoded as %40.
DATABASE_URL=mysql+pymysql://root:PASSWORD@localhost:3306/privacy
# Dev fallback: sqlite+pysqlite:///./privacy.dev.sqlite  (or sqlite:///./privacy.dev.sqlite)
CORS_ORIGIN=http://localhost:5181
UPLOAD_DIR=./_uploads

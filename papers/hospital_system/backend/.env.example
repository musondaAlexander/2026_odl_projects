# Copy to .env. NEVER commit the real .env.
PORT=4200
NODE_ENV=development

JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# MySQL (live server). Create it first: CREATE DATABASE hospital CHARACTER SET utf8mb4;
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital
DB_USER=root
DB_PASSWORD=

# Set DB_DIALECT=sqlite for a zero-setup dev DB (no MySQL needed).
SQLITE_STORAGE=./hospital.dev.sqlite

CORS_ORIGIN=http://localhost:5180

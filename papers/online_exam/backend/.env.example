# Spring Boot backend — copy to .env (or export) and adjust. Secrets are git-ignored.
SERVER_PORT=8080

# MySQL (the shared live server already has an `exam` database)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=exam
DB_USER=root
DB_PASSWORD=1234@abcd

# JWT signing
JWT_SECRET=online-exam-dev-secret-change-in-production-7f8e9d0c1b2a3948f5e6d7c8b9a0
JWT_EXPIRES_MS=86400000

# Python TF-IDF plagiarism microservice
PLAGIARISM_URL=http://localhost:8090

# React dev origin (CORS)
CORS_ORIGIN=http://localhost:5179

# Seed demo users + question bank + sample exam on first run
SEED_ENABLED=true

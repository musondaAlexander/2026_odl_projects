# Copy to .env. NEVER commit the real .env.
PORT=4300
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h

DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=root
DB_PASSWORD=
SQLITE_STORAGE=./ecommerce.dev.sqlite

# Payments: "mock" uses the built-in sandbox gateway; "live" requires real creds.
PAYMENTS_MODE=mock
CORS_ORIGIN=http://localhost:5182

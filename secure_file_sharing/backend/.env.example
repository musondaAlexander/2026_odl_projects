# Copy to .env and fill in. NEVER commit the real .env.
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Audit-log HMAC chain key (server-side integrity key). Rotate carefully.
AUDIT_HMAC_KEY=change-me-to-a-long-random-secret

# Database — MySQL (a MySQL server is already running locally).
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME
# Create the database first:  CREATE DATABASE sfs CHARACTER SET utf8mb4;
# Leave DATABASE_URL unset to fall back to local SQLite for quick dev.
DATABASE_URL=mysql://root:@localhost:3306/sfs

# Comma-separated CORS origins (the React dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173
